{
    "ui":  {
               "appearance_mode":  "Dark",
               "window_width":  1540,
               "window_height":  960,
               "min_width":  1320,
               "min_height":  820,
               "performance_profiler":  {
                                            "enabled":  true,
                                            "report_interval_seconds":  5,
                                            "history_size":  60,
                                            "persist_to_file":  true,
                                            "file_name":  "dave_perf_metrics.jsonl",
                                            "max_file_size_kb":  1024
                                        },
               "visual_system":  {
                                     "background":  "#08101D",
                                     "panel":  "#101B2E",
                                     "panel_elevated":  "#1A2942",
                                     "accent_primary":  "#7CEAFF",
                                     "accent_secondary":  "#42B7FF",
                                     "success":  "#5FE6AA",
                                     "warning":  "#FFC66D",
                                     "error":  "#FF6D6D",
                                     "text_primary":  "#ECF4FF",
                                     "text_secondary":  "#8FA7C6",
                                     "border":  "#31455F",
                                     "glass_tint":  "#243754",
                                     "glass_edge":  "#7EC8FF",
                                     "glass_shadow":  "#050A12",
                                     "skeuo_highlight":  "#D9ECFF",
                                     "skeuo_shadow":  "#0A1525"
                                 },
               "state_visuals":  {
                                     "NORMAL":  {
                                                    "accent":  "#00F5FF",
                                                    "glow":  "#43F6FF",
                                                    "ring_speed":  0.45,
                                                    "pulse_speed":  0.07
                                                },
                                     "LISTENING":  {
                                                       "accent":  "#57F8FF",
                                                       "glow":  "#8CFBFF",
                                                       "ring_speed":  0.42,
                                                       "pulse_speed":  0.1
                                                   },
                                     "PROCESSING":  {
                                                        "accent":  "#0090FF",
                                                        "glow":  "#47AFFF",
                                                        "ring_speed":  1.85,
                                                        "pulse_speed":  0.09
                                                    },
                                     "EXECUTING":  {
                                                       "accent":  "#00FF9C",
                                                       "glow":  "#70FFBF",
                                                       "ring_speed":  1.2,
                                                       "pulse_speed":  0.16
                                                   },
                                     "SPEAKING":  {
                                                      "accent":  "#3FE8FF",
                                                      "glow":  "#86F3FF",
                                                      "ring_speed":  0.65,
                                                      "pulse_speed":  0.12
                                                  },
                                     "ERROR":  {
                                                   "accent":  "#FF3B3B",
                                                   "glow":  "#FF8181",
                                                   "ring_speed":  1.4,
                                                   "pulse_speed":  0.2
                                               }
                                 }
           },
    "app":  {
                "version":  "0.3.0"
            },
    "brain":  {
                  "verbose_mode":  true
              },
    "llm":  {
                "enabled":  true,
                "allow_config_secrets":  false,
                "provider_order":  [
                                       "ollama",
                                       "groq",
                                       "gemini"
                                   ],
                "timeout_seconds":  14,
                "provider_retries":  1,
                "retry_backoff_seconds":  0.35,
                "retry_jitter_ratio":  0.35,
                "circuit_breaker_enabled":  true,
                "circuit_breaker_failure_threshold":  2,
                "circuit_breaker_cooldown_seconds":  18,
                "prefer_local":  true,
                "temperature":  0.2,
                "max_tokens":  300,
                "history_turns":  3,
                "intent_routing_enabled":  true,
                "intent_min_confidence":  0.58,
                "system_prompt":  "You are DAVE, a highly optimized desktop automation engine. You communicate strictly in clear, technical, and highly respectful terms. Omit conversational pleasantries unless explicitly greeted. Deliver precise, actionable data and execute commands with absolute efficiency. You are running on a Windows PC.",
                "groq":  {
                             "enabled":  true,
                             "api_key":  "",
                             "model":  "llama-3.1-8b-instant"
                         },
                "ollama":  {
                               "enabled":  true,
                               "url":  "http://localhost:11434/api/generate",
                               "model":  "llama3.2:3b",
                               "timeout_seconds":  14
                           },
                "gemini":  {
                               "enabled":  true,
                               "api_key":  "",
                               "model":  "gemini-2.5-flash",
                               "timeout_seconds":  14
                           },
                "dynamic_provider_selection":  true,
                "provider_sample_threshold":  2,
                "response_cache_enabled":  true,
                "response_cache_ttl_seconds":  120,
                "response_cache_max_entries":  256,
                "bootstrap_example_count":  1,
                "bootstrap_examples":  [
                                           {
                                               "user":  "hello dave",
                                               "assistant":  "Online. What do you need?"
                                           },
                                           {
                                               "user":  "open calculator",
                                               "assistant":  "Opening Calculator, Sir."
                                           },
                                           {
                                               "user":  "search for python threading",
                                               "assistant":  "Searching for python threading on the web."
                                           }
                                       ]
            },
    "update":  {
                   "enabled":  true,
                   "channel":  "stable",
                   "current_version":  "0.3.0",
                   "manifest_url":  "",
                   "check_on_startup":  false,
                   "request_timeout_seconds":  3.0
               },
    "voice":  {
                  "tts_backend":  "pyttsx3",
                  "tts_rate":  185,
                  "tts_volume":  1.0,
                  "tts_voice_id":  "",
                  "microphone_device_index":  null,
                  "pause_threshold":  0.8,
                  "ambient_adjust_seconds":  1.0,
                  "mic_reprobe_interval_seconds":  8.0,
                  "listen_timeout":  3.0,
                  "phrase_time_limit":  7.0
              },
    "automation":  {
                       "allow_shell_commands":  true,
                       "shell_timeout_seconds":  60,
                       "shell_output_limit":  900
                   },
    "policy":  {
                   "enabled":  true,
                   "pending_confirmation_timeout_seconds":  30,
                   "shell_max_command_length":  900,
                   "blocked_shell_patterns":  [
                                                 "\\bshutdown(?:\\.exe)?\\b",
                                                 "\\brestart(?:-computer)?\\b",
                                                 "\\bformat(?:\\.com)?\\b",
                                                 "\\bdiskpart\\b",
                                                 "\\bbcdedit\\b",
                                                 "\\breg(?:\\.exe)?\\s+delete\\b",
                                                 "\\bcipher(?:\\.exe)?\\s+/w\\b"
                                             ],
                   "confirm_shell_patterns":  [
                                                 "\\b(?:remove-item|rm|del|erase)\\b",
                                                 "\\b(?:stop-process|taskkill)\\b",
                                                 "\\b(?:sc(?:\\.exe)?\\s+stop|net\\s+stop)\\b",
                                                 "\\bset-executionpolicy\\b"
                                             ]
               },
    "workflows":  {
                      "enabled":  true,
                      "max_steps":  10,
                      "max_depth":  1,
                      "stop_on_error":  true,
                      "definitions":  {
                                          "startup":  {
                                                          "description":  "Open your usual tools and quick context search.",
                                                          "steps":  [
                                                                        "open chrome",
                                                                        "open vscode",
                                                                        "search for project dashboard"
                                                                    ]
                                                      }
                                      }
                  },
    "memory":  {
                   "enabled":  true,
                   "top_k":  3,
                   "min_similarity":  0.35,
                   "scan_rows":  250
               },
    "predictive":  {
                       "enabled":  true,
                       "confidence_threshold":  0.85,
                       "idle_poll_seconds":  45,
                       "suggestion_cooldown_seconds":  240,
                       "train_interval_seconds":  86400,
                       "min_training_samples":  25
                   }
}
